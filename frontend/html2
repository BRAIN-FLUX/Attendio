<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Smart Attendance System</title>
    <style>
        body {
            font-family: Arial;
            text-align: center;
            background: #f4f6f9;
        }


    h1 {
        color: #2c3e50;
    }

    .container {
        margin-top: 20px;
    }

    video {
        border: 3px solid #333;
        border-radius: 10px;
    }

    button {
        padding: 10px 20px;
        margin: 10px;
        font-size: 16px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
    }

    .start {
        background-color: #27ae60;
        color: white;
    }

    .capture {
        background-color: #2980b9;
        color: white;
    }

    table {
        margin: 20px auto;
        border-collapse: collapse;
        width: 60%;
    }

    table, th, td {
        border: 1px solid black;
    }

    th, td {
        padding: 10px;
    }

    th {
        background-color: #2c3e50;
        color: white;
    }
</style>


</head>
<body>


<h1>Smart Attendance System</h1>

<div class="container">
    <video id="video" width="400" height="300" autoplay></video>
    <br>
    <button class="start" onclick="startCamera()">Start Camera</button>
    <button class="capture" onclick="capture()">Capture</button>
</div>

<h2>Attendance</h2>

<table>
    <thead>
        <tr>
            <th>Name</th>
            <th>Time</th>
        </tr>
    </thead>
    <tbody id="attendanceTable">
    </tbody>
</table>


<script>
    let video = document.getElementById("video");

    function startCamera() {
        navigator.mediaDevices.getUserMedia({ video: true })
        .then(stream => {
            video.srcObject = stream;
        })
        .catch(err => {
            alert("Camera access denied!");
        });
    }

    function capture() {
        let table = document.getElementById("attendanceTable");

        // Dummy data (later connect with backend)
        let name = "Detected User";
        let time = new Date().toLocaleTimeString();

        let row = table.insertRow();
        row.insertCell(0).innerHTML = name;
        row.insertCell(1).innerHTML = time;
    }
</script>

</body>
</html>
